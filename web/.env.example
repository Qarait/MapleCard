# Default fixture-first frontend mode for UI development and tests.
VITE_MAPLECARD_API_MODE=fixture
VITE_MAPLECARD_API_BASE_URL=http://localhost:3000

# To run the web client against the local MapleCard backend instead, copy this file to:
# web/.env.local
#
# Then set:
# VITE_MAPLECARD_API_MODE=backend
# VITE_MAPLECARD_API_BASE_URL=http://localhost:3000