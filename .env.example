# MapleCard backend environment example
# Backend only. Do not place these values in web/.env files.
# Do not commit real credential values.

MAPLECARD_CATALOG_SOURCE=synthetic
MAPLECARD_PARSER_MODE=deterministic_only

KROGER_PROVIDER_ENABLED=false
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=
KROGER_DEFAULT_ZIP_CODE=
KROGER_DEFAULT_LOCATION_ID=
KROGER_BASE_URL=https://api.kroger.com/v1
KROGER_TOKEN_URL=https://api.kroger.com/v1/connect/oauth2/token
KROGER_TIMEOUT_MS=5000
KROGER_MAX_PRODUCTS_PER_QUERY=10