{
  "name": "maplecard",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:web": "npm --prefix web run dev",
    "build:backend": "tsc -p tsconfig.json",
    "build:web": "npm --prefix web run build",
    "build": "npm run build:backend && npm run build:web",
    "start": "node dist/index.js",
    "test:backend": "vitest run",
    "test:web": "npm --prefix web run test",
    "test": "npm run test:backend && npm run test:web"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/supertest": "^6.0.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3",
    "supertest": "^7.1.1",
    "vitest": "^3.2.4"
  }
}

